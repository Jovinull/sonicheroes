#!/bin/sh
#
# Refuses any commit that stages original game data or anything derived from it.
#
# The .gitignore already keeps orig/ and build/ out, but a stray `git add -f`, a
# new extension nobody thought about, or a moment of inattention would slip past
# it. This check runs on every commit and does not depend on anyone remembering
# to look.
#
# Enabled by `git config core.hooksPath .githooks`, which the README asks
# contributors to run once after cloning.
#
# Four layers, because any one of them has a hole:
#   1. extensions of game data and of build output
#   2. anything under orig/, which holds the contributor's own copy
#   3. anything under build/, where the disassembly of the disc lives
#   4. a size ceiling, to catch formats this list has never heard of

staged=$(git diff --cached --name-only --diff-filter=AM)
[ -z "$staged" ] && exit 0

fail() {
    echo "pre-commit: refusing to commit. $1" >&2
    echo "" >&2
    printf '%s\n' "$2" | sed 's/^/  /' >&2
    echo "" >&2
    echo "This repository must never contain game code, game assets, or" >&2
    echo "assembly extracted from the disc. See LEGAL.md. Unstage with:" >&2
    echo "  git restore --staged <file>" >&2
    exit 1
}

# 1. Disc images, executables, archives, common GameCube asset containers, and
#    build output.
blocked=$(printf '%s\n' "$staged" | grep -Ei '\.(dol|rel|rvz|iso|gcm|wbfs|ciso|gcz|nfs|tgc|arc|szs|szp|thp|gvr|adx|dsp|ast|bin|o|a|elf|plf|map|lcf|one|txd|dff|tpl|bnr|brres|rarc|u8|bmg|bti)$')
[ -n "$blocked" ] && fail "These staged files look like game data or build output:" "$blocked"

# 1b. Assembly source files, with their own message. A .s here is far more
#     likely to be a chunk of build/ that got copied into the tree than
#     something a person wrote, and the two are indistinguishable to a hook.
#     The convention is that hand written assembly goes inline in a .c file, so
#     nothing legitimate needs a .s and there are none in the repository.
asmsrc=$(printf '%s\n' "$staged" | grep -Ei '\.(s|inc)$')
if [ -n "$asmsrc" ]; then
    echo "pre-commit: refusing to commit assembly source files." >&2
    echo "" >&2
    printf '%s\n' "$asmsrc" | sed 's/^/  /' >&2
    echo "" >&2
    echo "This project keeps hand written assembly inline in .c files, as asm" >&2
    echo "blocks, so a .s in the tree is almost always disassembly copied out" >&2
    echo "of build/, which must never be committed. See LEGAL.md." >&2
    echo "" >&2
    echo "If you genuinely need a standalone assembly file, raise it first." >&2
    echo "git commit --no-verify exists, but using it here is a decision about" >&2
    echo "the project, not a formality." >&2
    exit 1
fi

# 2. orig/ holds the contributor's own copy of the game. Only .gitkeep belongs.
stray_orig=$(printf '%s\n' "$staged" | grep -E '^orig/' | grep -v '\.gitkeep$')
[ -n "$stray_orig" ] && fail "These staged files are under orig/:" "$stray_orig"

# 3. Everything under build/ is derived from the disc, whatever it is called.
stray_build=$(printf '%s\n' "$staged" | grep -E '^build/')
[ -n "$stray_build" ] && fail "These staged files are under build/:" "$stray_build"

# 4. A large binary is the shape game data arrives in, whatever its extension.
#    Only binaries are checked: `config/G9SE8P/symbols.txt` is well over a
#    megabyte and entirely legitimate, so a size ceiling on text would fire on
#    every commit that touches it. git reports binary files as "-" in numstat,
#    which is how they are told apart here.
big=$(git diff --cached --numstat --diff-filter=AM -z \
    | tr '\0' '\n' \
    | awk -F'\t' '$1 == "-" && $2 == "-" { print $3 }' \
    | while IFS= read -r f; do
          [ -z "$f" ] && continue
          size=$(git cat-file -s "$(git rev-parse ":$f" 2>/dev/null)" 2>/dev/null)
          [ -n "$size" ] && [ "$size" -gt 524288 ] && echo "$f ($size bytes)"
      done)
[ -n "$big" ] && fail "These staged binaries are over 512 KB:" "$big"

exit 0
